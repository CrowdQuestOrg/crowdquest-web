{
  "rewrites": [
    {
      "source": "/@fs/(.*)",
      "destination": "/@fs/$1"
    },
    {
      "source": "/@vite/(.*)", 
      "destination": "/@vite/$1"
    },
    {
      "source": "/node_modules/(.*)",
      "destination": "/node_modules/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/(.*)\\.(js|css|ts|tsx|jsx|json|png|jpg|jpeg|svg|gif|ico|webp|woff|woff2|ttf|eot|map)$",
      "destination": "/$1.$2"
    },
    {
      "source": "/((?!api/|_next/|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
